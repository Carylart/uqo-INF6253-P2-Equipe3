    <rdfs:subClassOf rdf:nodeID="N81145174e4cc43139d1f7f30a9bcc4c5"/>
    <obo:IAO_0000115>A form of programmed cell death induced by external or internal signals that trigger the activity of proteolytic caspases, whose actions dismantle a cardiac muscle cell and result in its death. Cardiac muscle cells are striated muscle cells that are responsible for heart contraction.</obo:IAO_0000115>
    <dcterms:conformsTo rdf:resource="http://purl.obolibrary.org/obo/go/patterns/occursIn.yaml"/>
    <oboInOwl:hasNarrowSynonym>cardiac muscle cell apoptosis</oboInOwl:hasNarrowSynonym>
    <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
    <oboInOwl:id>GO:0010659</oboInOwl:id>
    <rdfs:label>cardiac muscle cell apoptotic process</rdfs:label>
  </rdf:Description>
