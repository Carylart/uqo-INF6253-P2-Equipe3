    <oboInOwl:hasOBONamespace>cellular_component</oboInOwl:hasOBONamespace>
    <oboInOwl:id>GO:1990722</oboInOwl:id>
    <rdfs:label>DAPK1-calmodulin complex</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0070227">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="N272f710467c04673ae0b566670da88fd"/>
