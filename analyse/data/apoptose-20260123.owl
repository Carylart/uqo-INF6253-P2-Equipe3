  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0097191">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007166"/>
