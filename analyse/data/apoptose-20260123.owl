    <rdfs:subClassOf rdf:nodeID="Nf80de8cb450844f48832e5185c80ac61"/>
    <obo:IAO_0000115>A process in which a symbiont gene product alters or subverts host programmed cell death, leading to a change in the frequency, rate or extent of host programmed cell death in the host cell. The host is defined as the larger of the organisms involved in a symbiotic interaction.</obo:IAO_0000115>
    <obo:IAO_0000233 rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://github.com/geneontology/go-ontology/issues/25986</obo:IAO_0000233>
    <obo:RO_0002161 rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_33090"/>
    <obo:RO_0002161 rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_4895"/>
    <obo:RO_0002161 rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_7742"/>
    <oboInOwl:hasAlternativeId>GO:0052152</oboInOwl:hasAlternativeId>
    <oboInOwl:hasExactSynonym>modulation by symbiont of host programmed cell death</oboInOwl:hasExactSynonym>
    <oboInOwl:hasExactSynonym>modulation of host PCD</oboInOwl:hasExactSynonym>
    <oboInOwl:hasNarrowSynonym>modulation by symbiont of host non-apoptotic programmed cell death</oboInOwl:hasNarrowSynonym>
    <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
    <oboInOwl:id>GO:0052040</oboInOwl:id>
    <rdfs:label>symbiont-mediated perturbation of host programmed cell death</rdfs:label>
  </rdf:Description>
