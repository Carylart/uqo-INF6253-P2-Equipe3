    <obo:IAO_0000115>Synergid cells undergo degeneration and death in response to penetration by the pollen tube. It is an active process that involves a dramatic decrease in cell volume, collapse of the vacuoles, and complete disintegration of the plasma membrane and most organelles.</obo:IAO_0000115>
    <oboInOwl:hasAlternativeId>GO:0048470</oboInOwl:hasAlternativeId>
    <oboInOwl:hasExactSynonym>synergid cell death</oboInOwl:hasExactSynonym>
    <oboInOwl:hasExactSynonym>synergid degeneration</oboInOwl:hasExactSynonym>
    <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
    <oboInOwl:id>GO:0010198</oboInOwl:id>
    <rdfs:label>synergid death</rdfs:label>
  </rdf:Description>
