  <rdf:Description rdf:nodeID="Neab6b75477d74ca0a8cbf6622564fbe0">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002211"/>
