  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0036483">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="N847653b5d6454787bf45e6c970c6c02b"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0070059"/>
    <rdfs:subClassOf rdf:nodeID="N51638101669948cc89f67c05aace6af0"/>
    <rdfs:subClassOf rdf:nodeID="N73e04b132e0a4508907330c05f90d2a7"/>
