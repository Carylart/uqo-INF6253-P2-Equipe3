    <rdfs:subClassOf rdf:nodeID="Nfafd11bb0c9b4f219943c86ebce62d34"/>
    <obo:IAO_0000115>The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a cell. The pathway is induced in response to nitrosative stress; a state often resulting from exposure to high levels of nitric oxide (NO) or the highly reactive oxidant peroxynitrite, which is produced following interaction of NO with superoxide anions.</obo:IAO_0000115>
    <obo:RO_0002161 rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_4896"/>
    <oboInOwl:created_by>bf</oboInOwl:created_by>
    <oboInOwl:creation_date>2014-07-31T14:28:16Z</oboInOwl:creation_date>
    <oboInOwl:hasExactSynonym>nitrosative stress-induced intrinsic apoptotic signaling pathway</oboInOwl:hasExactSynonym>
    <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
    <oboInOwl:hasRelatedSynonym>nitrosative stress-induced apoptosis</oboInOwl:hasRelatedSynonym>
    <oboInOwl:id>GO:1990442</oboInOwl:id>
    <rdfs:label>intrinsic apoptotic signaling pathway in response to nitrosative stress</rdfs:label>
  </rdf:Description>
