    <rdfs:subClassOf rdf:nodeID="N8c473d831b20455b82733f511326fb75"/>
    <obo:IAO_0000115>Any apoptotic process in a lymphocyte, a leukocyte commonly found in the blood and lymph that has the characteristics of a large nucleus, a neutral staining cytoplasm, and prominent heterochromatin.</obo:IAO_0000115>
    <dcterms:conformsTo rdf:resource="http://purl.obolibrary.org/obo/go/patterns/occursIn.yaml"/>
    <oboInOwl:hasNarrowSynonym>lymphocyte apoptosis</oboInOwl:hasNarrowSynonym>
    <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
    <oboInOwl:id>GO:0070227</oboInOwl:id>
    <rdfs:comment>Note that a lymphocyte is a cell of the B cell, T cell, or natural killer cell lineage (CL:0000542).</rdfs:comment>
    <rdfs:label>lymphocyte apoptotic process</rdfs:label>
  </rdf:Description>
