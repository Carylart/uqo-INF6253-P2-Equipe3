  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0008628">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0009755"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0097190"/>
    <rdfs:subClassOf rdf:nodeID="N4a297a9c2b0f4a328bf0f653b24997c9"/>
    <rdfs:subClassOf rdf:nodeID="Nd15c07b38be644299507e57a441456fa"/>
    <obo:IAO_0000115>The series of molecular signals mediated by the detection of a hormone, and which triggers the apoptotic signaling pathway in a cell. The pathway starts with reception of a hormone signal, and ends when the execution phase of apoptosis is triggered.</obo:IAO_0000115>
    <obo:IAO_0000233 rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://wiki.geneontology.org/index.php/Apoptosis_Curation_Manual#Other_children_of_apoptotic_signaling_pathway</obo:IAO_0000233>
    <obo:RO_0002161 rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_4751"/>
    <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
    <oboInOwl:hasRelatedSynonym>apoptotic signaling pathway in response to hormone</oboInOwl:hasRelatedSynonym>
    <oboInOwl:hasRelatedSynonym>induction of apoptosis by hormones</oboInOwl:hasRelatedSynonym>
    <oboInOwl:id>GO:0008628</oboInOwl:id>
    <rdfs:comment>This term is placed under GO:0097190 apoptotic signaling pathway, rather than under one of its more specific children terms, to cover for the variety of apoptosis signaling mechanisms that different hormones may use.</rdfs:comment>
    <rdfs:label>hormone-mediated apoptotic signaling pathway</rdfs:label>
  </rdf:Description>
