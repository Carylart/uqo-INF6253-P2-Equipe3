    <rdfs:subClassOf rdf:nodeID="N8dd4282923884d5f9ee4f2577f5fb63f"/>
    <obo:IAO_0000115>The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a cell. The pathway is induced by the detection of DNA damage, and ends when the execution phase of apoptosis is triggered.</obo:IAO_0000115>
    <obo:RO_0002161 rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_4896"/>
    <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
