  <rdf:Description rdf:nodeID="Nc9b954eb23164829a1301768a0d8cd25">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/GO_0070268"/>
    <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
    <owl:annotatedTarget>A type of programmed cell death that occurs in the epidermis, morphologically and biochemically distinct from apoptosis. It leads to the formation of corneocytes, i.e. dead keratinocytes containing an amalgam of specific proteins (e.g., keratin, loricrin, SPR and involucrin) and lipids (e.g., fatty acids and ceramides), which are necessary for the function of the cornified skin layer (mechanical resistance, elasticity, water repellence and structural stability).</owl:annotatedTarget>
    <oboInOwl:hasDbXref>GOC:krc</oboInOwl:hasDbXref>
    <oboInOwl:hasDbXref>PMID:18846107</oboInOwl:hasDbXref>
  </rdf:Description>
