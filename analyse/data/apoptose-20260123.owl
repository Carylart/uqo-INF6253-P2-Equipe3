  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0010659">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="Nad8f00df61a84861a1a398ac21e57d61"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0010658"/>
