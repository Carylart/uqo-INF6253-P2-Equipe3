  <rdf:Description rdf:nodeID="Nc2f3accbb5204406be2d2ff416a9b81b">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/GO_0006915"/>
    <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
    <owl:annotatedTarget>A programmed cell death process which begins when a cell receives an internal (e.g. DNA damage) or external signal (e.g. an extracellular death ligand), and proceeds through a series of biochemical events (signaling pathway phase) which trigger an execution phase. The execution phase is the last step of an apoptotic process, and is typically characterized by rounding-up of the cell, retraction of pseudopodes, reduction of cellular volume (pyknosis), chromatin condensation, nuclear fragmentation (karyorrhexis), plasma membrane blebbing and fragmentation of the cell into apoptotic bodies. When the execution phase is completed, the cell has died.</owl:annotatedTarget>
    <oboInOwl:hasDbXref>GOC:cjm</oboInOwl:hasDbXref>
    <oboInOwl:hasDbXref>GOC:dhl</oboInOwl:hasDbXref>
    <oboInOwl:hasDbXref>GOC:ecd</oboInOwl:hasDbXref>
    <oboInOwl:hasDbXref>GOC:go_curators</oboInOwl:hasDbXref>
    <oboInOwl:hasDbXref>GOC:mtg_apoptosis</oboInOwl:hasDbXref>
    <oboInOwl:hasDbXref>GOC:tb</oboInOwl:hasDbXref>
    <oboInOwl:hasDbXref>ISBN:0198506732</oboInOwl:hasDbXref>
    <oboInOwl:hasDbXref>PMID:18846107</oboInOwl:hasDbXref>
    <oboInOwl:hasDbXref>PMID:21494263</oboInOwl:hasDbXref>
  </rdf:Description>
