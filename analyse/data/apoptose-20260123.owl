  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0001780">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <obo:IAO_0000115>The process of regulating the proliferation and elimination of neutrophils such that the total number of neutrophils within a whole or part of an organism is stable over time in the absence of an outside stimulus.</obo:IAO_0000115>
    <rdfs:comment>Note that this term represents the return of neutrophil levels to stable numbers following an immune response as well as the proliferation and elimination of neutrophils required to maintain stable numbers in the absence of an outside stimulus.</rdfs:comment>
    <rdfs:label>neutrophil homeostasis</rdfs:label>
  </rdf:Description>
