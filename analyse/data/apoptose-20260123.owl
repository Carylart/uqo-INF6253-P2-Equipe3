    <rdfs:subClassOf rdf:nodeID="N55892f909bf444fe931a6953bea68908"/>
    <obo:IAO_0000115>Any process that increases the rate or extent of cardiac cell apoptotic process, a form of programmed cell death induced by external or internal signals that trigger the activity of proteolytic caspases whose actions dismantle a cardiac muscle cell and result in its death.</obo:IAO_0000115>
    <dcterms:conformsTo rdf:resource="http://purl.obolibrary.org/obo/go/patterns/positive_regulation.yaml"/>
    <oboInOwl:hasNarrowSynonym>positive regulation of cardiac muscle cell apoptosis</oboInOwl:hasNarrowSynonym>
    <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
    <oboInOwl:id>GO:0010666</oboInOwl:id>
    <rdfs:label>positive regulation of cardiac muscle cell apoptotic process</rdfs:label>
  </rdf:Description>
