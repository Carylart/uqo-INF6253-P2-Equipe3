    <oboInOwl:hasOBONamespace>cellular_component</oboInOwl:hasOBONamespace>
    <oboInOwl:id>GO:0106093</oboInOwl:id>
    <rdfs:comment>Interacts with the R genes triggering ETI and systemic resistance.</rdfs:comment>
