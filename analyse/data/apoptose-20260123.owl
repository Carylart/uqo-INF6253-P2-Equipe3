  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0140507">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0007165"/>
    <rdfs:subClassOf rdf:nodeID="N823bd5dc96f541359b43990160b51be6"/>
    <obo:IAO_0000115>The series of molecular signals induced by granzymes which triggers the cell death of a cell. The pathway starts with reception of a granzyme signal, and ends when the execution phase of cell death is triggered. Granzymes are serine proteases that are secreted by cytotoxic T cells and natural killer cells to induce cell death in target cells.</obo:IAO_0000115>
    <obo:IAO_0000233 rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://wiki.geneontology.org/index.php/Apoptosis_Curation_Manual#Other_children_of_apoptotic_signaling_pathway</obo:IAO_0000233>
    <obo:IAO_0000233 rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://github.com/geneontology/go-ontology/issues/19901</obo:IAO_0000233>
    <oboInOwl:created_by>pg</oboInOwl:created_by>
    <oboInOwl:creation_date>2020-08-27T13:51:40Z</oboInOwl:creation_date>
    <oboInOwl:hasBroadSynonym>granzyme-mediated cell death signaling pathway</oboInOwl:hasBroadSynonym>
    <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
    <oboInOwl:id>GO:0140507</oboInOwl:id>
    <rdfs:label>granzyme-mediated programmed cell death signaling pathway</rdfs:label>
  </rdf:Description>
