  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0052151">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <owl:equivalentClass rdf:nodeID="N5a46ac417ffe416baafc9dc812c50224"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0001907"/>
