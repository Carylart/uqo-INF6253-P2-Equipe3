  <rdf:Description rdf:nodeID="Nb42f9dab00704bf2bd187e5102d568a0">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Axiom"/>
    <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/GO_0033668"/>
    <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
    <owl:annotatedTarget>A process in which a symbiont inhibits or disrupts the normal execution of host apoptosis, leading to a decrease in the frequency, rate or extent of apoptosis in the host cell. The host is defined as the larger of the organisms involved in a symbiotic interaction.</owl:annotatedTarget>
    <oboInOwl:hasDbXref>GOC:curators</oboInOwl:hasDbXref>
  </rdf:Description>
