  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0008631">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0097193"/>
    <rdfs:subClassOf rdf:nodeID="N7b886ff727dd4c19a991a8e5c6815761"/>
    <rdfs:subClassOf rdf:nodeID="N94866552584d4022b5f5a5b0c74ee71d"/>
    <obo:IAO_0000115>The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a cell. The pathway is induced in response to oxidative stress, a state often resulting from exposure to high levels of reactive oxygen species, and ends when the execution phase of apoptosis is triggered.</obo:IAO_0000115>
    <obo:RO_0002161 rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_4896"/>
    <oboInOwl:hasExactSynonym>oxidative stress-induced intrinsic apoptotic signaling pathway</oboInOwl:hasExactSynonym>
    <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
    <oboInOwl:hasRelatedSynonym>induction of apoptosis by oxidative stress</oboInOwl:hasRelatedSynonym>
    <oboInOwl:id>GO:0008631</oboInOwl:id>
    <rdfs:label>intrinsic apoptotic signaling pathway in response to oxidative stress</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="Nd5ecf6fe71dd445e981ac597002d9bb9">
