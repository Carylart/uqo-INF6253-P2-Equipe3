    <oboInOwl:id>GO:0008630</oboInOwl:id>
    <rdfs:label>intrinsic apoptotic signaling pathway in response to DNA damage</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:about="http://purl.obolibrary.org/obo/GO_0010666">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
