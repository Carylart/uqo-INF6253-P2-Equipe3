    <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
    <owl:annotatedTarget>The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a cell. The pathway is induced by the cell cycle regulator phosphoprotein p53, or an equivalent protein, in response to the detection of DNA damage, and ends when the execution phase of apoptosis is triggered.</owl:annotatedTarget>
    <oboInOwl:hasDbXref>GOC:go_curators</oboInOwl:hasDbXref>
    <oboInOwl:hasDbXref>GOC:mtg_apoptosis</oboInOwl:hasDbXref>
