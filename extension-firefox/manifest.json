{
  "manifest_version": 2,
  "name": "GO Evolution Tracker",
  "version": "1.0.0",
  "description": "Extension pour suivre l'évolution des termes Gene Ontology entre différentes versions",
  "permissions": [
    "storage",
    "activeTab",
    "https://www.ebi.ac.uk/*",
    "http://amigo.geneontology.org/*",
    "https://www.ebi.ac.uk/ols/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.ebi.ac.uk/QuickGO/term/*",
        "http://amigo.geneontology.org/amigo/term/*",
        "https://www.ebi.ac.uk/ols/ontologies/go/terms*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
