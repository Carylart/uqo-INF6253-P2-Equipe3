<http://purl.obolibrary.org/obo/GO_0072332/2026-01-23> a evo:TermVersion ;
    evo:definition "The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a cell. The pathway is induced by the cell cycle regulator phosphoprotein p53, or an equivalent protein, and ends when the execution phase of apoptosis is triggered." ;
    evo:isDeprecated false ;
    evo:label "intrinsic apoptotic signaling pathway by p53 class mediator" ;
