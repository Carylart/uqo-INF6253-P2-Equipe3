<http://purl.obolibrary.org/obo/GO_0052040/2025-10-10> a evo:TermVersion ;
    evo:definition "A process in which a symbiont gene product alters or subverts host programmed cell death, leading to a change in the frequency, rate or extent of host programmed cell death in the host cell. The host is defined as the larger of the organisms involved in a symbiotic interaction." ;
    evo:isDeprecated false ;
    evo:label "symbiont-mediated perturbation of host programmed cell death" ;
    evo:parent go:GO_0044068 ;
    evo:termID "GO:0052040" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0052041/2025-10-10> a evo:TermVersion ;
    evo:definition "A process in which a symbiont inhibits or disrupts the normal execution of host programmed cell death, leading to a decrease in the frequency, rate or extent of programmed cell death in the host cell. The host is defined as the larger of the organisms involved in a symbiotic interaction." ;
    evo:isDeprecated false ;
    evo:label "symbiont-mediated suppression of host programmed cell death" ;
    evo:parent go:GO_0052040 ;
    evo:termID "GO:0052041" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0052042/2025-10-10> a evo:TermVersion ;
    evo:definition "A process in which a symbiont gene product activates host programmed cell death, leading to an increase in the frequency, rate or extent of programmed cell death in the host cell. The host is defined as the larger of the organisms involved in a symbiotic interaction." ;
    evo:isDeprecated false ;
    evo:label "symbiont-mediated activation of host programmed cell death" ;
    evo:parent go:GO_0052040 ;
    evo:termID "GO:0052042" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0052150/2025-10-10> a evo:TermVersion ;
    evo:definition "A process in which a symbiont gene product affects host apoptosis, leading to a change in the frequency, rate or extent of apoptosis in the host cell. The host is defined as the larger of the organisms involved in a symbiotic interaction." ;
    evo:isDeprecated false ;
    evo:label "symbiont-mediated perturbation of host apoptosis" ;
    evo:parent go:GO_0051709,
        go:GO_0052040 ;
    evo:termID "GO:0052150" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0052151/2025-10-10> a evo:TermVersion ;
    evo:definition "A process in which a symbiont initiates, promotes, or enhances the normal execution of host apoptosis, leading to an increase in the frequency, rate or extent of apoptosis in the host cell. The host is defined as the larger of the organisms involved in a symbiotic interaction." ;
    evo:isDeprecated false ;
    evo:label "symbiont-mediated activation of host apoptosis" ;
    evo:parent go:GO_0001907,
        go:GO_0052042,
        go:GO_0052150 ;
    evo:termID "GO:0052151" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0052158/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process in which a symbiont modulates the frequency, rate or extent of the resistance gene-dependent defense response of the host organism. The host is defined as the larger of the organisms involved in a symbiotic interaction." ;
    evo:isDeprecated false ;
    evo:label "symbiont-mediated perturbation of host resistance gene-dependent defense response" ;
    evo:termID "GO:0052158" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0055045/2025-10-10> a evo:TermVersion ;
    evo:definition "The process in which the antipodal cells undergo programmed cell death." ;
