    evo:termID "GO:0030263" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0030264/2025-10-10> a evo:TermVersion ;
    evo:definition "The breakdown of the nucleus into small membrane-bounded compartments, or blebs, each of which contain compacted DNA." ;
    evo:isDeprecated false ;
    evo:label "nuclear fragmentation involved in apoptotic nuclear change" ;
    evo:parent go:GO_0071763 ;
    evo:termID "GO:0030264" ;
