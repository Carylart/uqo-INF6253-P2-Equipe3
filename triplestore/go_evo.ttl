    evo:definition "The tissue remodeling that removes differentiated mammary epithelia during weaning." ;
    evo:isDeprecated false ;
    evo:label "mammary gland involution" ;
    evo:termID "GO:0060056" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0060057/2025-10-10> a evo:TermVersion ;
    evo:definition "Any apoptotic process that triggers the activity of proteolytic caspases whose actions dismantle the mammary epithelial cells resulting in their programmed cell death." ;
    evo:isDeprecated false ;
    evo:label "apoptotic process involved in mammary gland involution" ;
    evo:parent go:GO_0060561 ;
