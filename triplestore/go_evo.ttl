<http://purl.obolibrary.org/obo/GO_0052042/2026-01-23> a evo:TermVersion ;
    evo:definition "A process in which a symbiont gene product activates host programmed cell death, leading to an increase in the frequency, rate or extent of programmed cell death in the host cell. The host is defined as the larger of the organisms involved in a symbiotic interaction." ;
    evo:isDeprecated false ;
    evo:label "symbiont-mediated activation of host programmed cell death" ;
    evo:parent go:GO_0052040 ;
