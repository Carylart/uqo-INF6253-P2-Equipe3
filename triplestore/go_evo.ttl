<http://purl.obolibrary.org/obo/GO_0072577/2026-01-23> a evo:TermVersion ;
    evo:definition "Any apoptotic process in an endothelial cell. An endothelial cell comprises the outermost layer or lining of anatomical structures and can be squamous or cuboidal." ;
    evo:isDeprecated false ;
    evo:label "endothelial cell apoptotic process" ;
    evo:parent go:GO_0006915 ;
