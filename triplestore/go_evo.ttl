<http://purl.obolibrary.org/obo/GO_0009967/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that activates or increases the frequency, rate or extent of signal transduction." ;
    evo:isDeprecated false ;
    evo:label "positive regulation of signal transduction" ;
