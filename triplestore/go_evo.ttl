<http://purl.obolibrary.org/obo/GO_0072331/2026-01-23> a evo:TermVersion ;
    evo:definition "An intracellular signaling process that is induced by the cell cycle regulator phosphoprotein p53 or an equivalent protein." ;
    evo:isDeprecated false ;
    evo:label "signal transduction by p53 class mediator" ;
