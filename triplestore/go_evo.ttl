<http://purl.obolibrary.org/obo/GO_0003006/2025-10-10> a evo:TermVersion ;
    evo:definition "A developmental process in which a progressive change in the state of some part of an organism, germline or somatic, specifically contributes to its ability to form offspring." ;
    evo:isDeprecated false ;
    evo:label "developmental process involved in reproduction" ;
    evo:termID "GO:0003006" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0003007/2025-10-10> a evo:TermVersion ;
    evo:definition "The developmental process in which the heart is generated and organized. The heart is a hollow, muscular organ, which, by contracting rhythmically, keeps up the circulation of the blood." ;
    evo:isDeprecated false ;
    evo:label "heart morphogenesis" ;
    evo:termID "GO:0003007" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0003151/2025-10-10> a evo:TermVersion ;
    evo:definition "The process in which the anatomical structures of the outflow tract are generated and organized. The outflow tract is the portion of the heart through which blood flows into the arteries." ;
    evo:isDeprecated false ;
    evo:label "outflow tract morphogenesis" ;
    evo:termID "GO:0003151" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0003203/2025-10-10> a evo:TermVersion ;
    evo:definition "The process in which the anatomical structure of the endocardial cushion is generated and organized. The endocardial cushion is a specialized region of mesenchymal cells that will give rise to the heart septa and valves." ;
    evo:isDeprecated false ;
    evo:label "endocardial cushion morphogenesis" ;
    evo:termID "GO:0003203" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0003275/2025-10-10> a evo:TermVersion ;
    evo:definition "Any apoptotic process that contributes to the shaping of the outflow tract. The outflow tract is the portion of the heart through which blood flows into the arteries." ;
    evo:isDeprecated false ;
    evo:label "apoptotic process involved in outflow tract morphogenesis" ;
    evo:parent go:GO_0003278 ;
    evo:termID "GO:0003275" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0003277/2025-10-10> a evo:TermVersion ;
    evo:definition "Any apoptotic process that contributes to the shaping of an endocardial cushion. The endocardial cushion is a specialized region of mesenchymal cells that will give rise to the heart septa and valves." ;
    evo:isDeprecated false ;
    evo:label "apoptotic process involved in endocardial cushion morphogenesis" ;
    evo:parent go:GO_0003278 ;
    evo:termID "GO:0003277" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0003278/2025-10-10> a evo:TermVersion ;
    evo:definition "Any apoptotic process that contributes to the shaping of the heart." ;
    evo:isDeprecated false ;
    evo:label "apoptotic process involved in heart morphogenesis" ;
    evo:parent go:GO_0060561 ;
    evo:termID "GO:0003278" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0004683/2025-10-10> a evo:TermVersion ;
    evo:definition "Calmodulin-dependent catalysis of the reactions: ATP + a protein serine = ADP + protein serine phosphate; and ATP + a protein threonine = ADP + protein threonine phosphate. This activity require the presence of calcium-bound calmodulin." ;
    evo:isDeprecated false ;
    evo:label "calcium/calmodulin-dependent protein kinase activity" ;
    evo:termID "GO:0004683" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0004888/2025-10-10> a evo:TermVersion ;
    evo:definition "Combining with an extracellular or intracellular signal and transmitting the signal from one side of the membrane to the other to initiate a change in cell activity or state as part of signal transduction." ;
    evo:isDeprecated false ;
    evo:label "transmembrane signaling receptor activity" ;
    evo:termID "GO:0004888" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0005031/2025-10-10> a evo:TermVersion ;
    evo:definition "Combining with tumor necrosis factor, a proinflammatory cytokine produced by monocytes and macrophages, to initiate a change in cell function." ;
    evo:isDeprecated false ;
    evo:label "tumor necrosis factor receptor activity" ;
    evo:parent go:GO_0005035 ;
    evo:termID "GO:0005031" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0005035/2025-10-10> a evo:TermVersion ;
    evo:definition "Combining with an extracellular messenger (called a death ligand), and transmitting the signal from one side of the plasma membrane to the other to initiate apoptotic or necrotic cell death." ;
    evo:isDeprecated false ;
    evo:label "death receptor activity" ;
    evo:parent go:GO_0004888 ;
    evo:termID "GO:0005035" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0005123/2025-10-10> a evo:TermVersion ;
    evo:definition "Binding to a member of the death receptor (DR) family. The DR family falls within the tumor necrosis factor receptor superfamily and is characterized by a cytoplasmic region of ~80 residues termed the death domain (DD)." ;
    evo:isDeprecated false ;
    evo:label "death receptor binding" ;
    evo:termID "GO:0005123" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0006308/2025-10-10> a evo:TermVersion ;
    evo:definition "The cellular DNA metabolic process resulting in the breakdown of DNA, deoxyribonucleic acid, one of the two main types of nucleic acid, consisting of a long unbranched macromolecule formed from one or two strands of linked deoxyribonucleotides, the 3'-phosphate group of each constituent deoxyribonucleotide being joined in 3',5'-phosphodiester linkage to the 5'-hydroxyl group of the deoxyribose moiety of the next one." ;
    evo:isDeprecated false ;
    evo:label "DNA catabolic process" ;
    evo:termID "GO:0006308" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0006309/2025-10-10> a evo:TermVersion ;
    evo:definition "The cleavage of DNA during apoptosis, which usually occurs in two stages: cleavage into fragments of about 50 kbp followed by cleavage between nucleosomes to yield 200 bp fragments." ;
    evo:isDeprecated false ;
    evo:label "apoptotic DNA fragmentation" ;
    evo:parent go:GO_0006308 ;
    evo:termID "GO:0006309" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0006915/2025-10-10> a evo:TermVersion ;
    evo:definition "A programmed cell death process which begins when a cell receives an internal (e.g. DNA damage) or external signal (e.g. an extracellular death ligand), and proceeds through a series of biochemical events (signaling pathway phase) which trigger an execution phase. The execution phase is the last step of an apoptotic process, and is typically characterized by rounding-up of the cell, retraction of pseudopodes, reduction of cellular volume (pyknosis), chromatin condensation, nuclear fragmentation (karyorrhexis), plasma membrane blebbing and fragmentation of the cell into apoptotic bodies. When the execution phase is completed, the cell has died." ;
    evo:isDeprecated false ;
    evo:label "apoptotic process" ;
    evo:parent go:GO_0012501 ;
    evo:termID "GO:0006915" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0006921/2025-10-10> a evo:TermVersion ;
    evo:definition "The breakdown of structures such as organelles, proteins, or other macromolecular structures during apoptosis." ;
    evo:isDeprecated false ;
    evo:label "cellular component disassembly involved in execution phase of apoptosis" ;
    evo:parent go:GO_0022411 ;
    evo:termID "GO:0006921" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0006924/2025-10-10> a evo:TermVersion ;
    evo:definition "A T cell apoptotic process that occurs towards the end of the expansion phase following the initial activation of mature T cells by antigen and is triggered by T cell receptor stimulation and signals transmitted via various surface-expressed members of the TNF receptor family such as Fas ligand, Fas, and TNF and the p55 and p75 TNF receptors." ;
    evo:isDeprecated false ;
    evo:label "activation-induced cell death of T cells" ;
    evo:parent go:GO_0070231 ;
    evo:termID "GO:0006924" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0006925/2025-10-10> a evo:TermVersion ;
    evo:definition "Any apoptotic process in an inflammatory cell, any cell participating in the inflammatory response to a foreign substance e.g. neutrophil, macrophage." ;
    evo:isDeprecated false ;
    evo:label "inflammatory cell apoptotic process" ;
    evo:parent go:GO_0006915 ;
    evo:termID "GO:0006925" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0006974/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that results in a change in state or activity of a cell (in terms of movement, secretion, enzyme production, gene expression, etc.) as a result of a stimulus indicating damage to its DNA from environmental insults or errors during metabolism." ;
    evo:isDeprecated false ;
    evo:label "DNA damage response" ;
    evo:termID "GO:0006974" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0007005/2025-10-10> a evo:TermVersion ;
    evo:definition "A process that is carried out at the cellular level which results in the assembly, arrangement of constituent parts, or disassembly of a mitochondrion; includes mitochondrial morphogenesis and distribution, and replication of the mitochondrial genome as well as synthesis of new mitochondrial components." ;
    evo:isDeprecated false ;
    evo:label "mitochondrion organization" ;
    evo:termID "GO:0007005" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0007165/2025-10-10> a evo:TermVersion ;
    evo:definition "The cellular process in which a signal is conveyed to trigger a change in the activity or state of a cell. Signal transduction begins with reception of a signal (e.g. a ligand binding to a receptor or receptor activation by a stimulus such as light), or for signal transduction in the absence of ligand, signal-withdrawal or the activity of a constitutively active receptor. Signal transduction ends with regulation of a downstream cellular process, e.g. regulation of transcription or regulation of a metabolic process. Signal transduction covers signaling from receptors located on the surface of the cell and signaling via molecules located within the cell. For signaling between cells, signal transduction is restricted to events at and within the receiving cell." ;
    evo:isDeprecated false ;
    evo:label "signal transduction" ;
    evo:termID "GO:0007165" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0007166/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals initiated by an extracellular ligand binding to a receptor located on the cell surface. The pathway ends with regulation of a downstream cellular process, e.g. transcription." ;
    evo:isDeprecated false ;
    evo:label "cell surface receptor signaling pathway" ;
    evo:termID "GO:0007166" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0008219/2025-10-10> a evo:TermVersion ;
    evo:definition "Any biological process that results in permanent cessation of all vital functions of a cell. A cell should be considered dead when any one of the following molecular or morphological criteria is met: (1) the cell has lost the integrity of its plasma membrane; (2) the cell, including its nucleus, has undergone complete fragmentation into discrete bodies (frequently referred to as apoptotic bodies). The cell corpse (or its fragments) may be engulfed by an adjacent cell in vivo, but engulfment of whole cells should not be considered a strict criteria to define cell death as, under some circumstances, live engulfed cells can be released from phagosomes (see PMID:18045538)." ;
    evo:isDeprecated false ;
    evo:label "cell death" ;
    evo:termID "GO:0008219" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0008543/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals generated as a consequence of a fibroblast growth factor receptor binding to one of its physiological ligands." ;
    evo:isDeprecated false ;
    evo:label "fibroblast growth factor receptor signaling pathway" ;
    evo:termID "GO:0008543" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0008585/2025-10-10> a evo:TermVersion ;
    evo:definition "The process whose specific outcome is the progression of the female gonad over time, from its formation to the mature structure." ;
    evo:isDeprecated false ;
    evo:label "female gonad development" ;
    evo:termID "GO:0008585" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0008625/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals in which a signal is conveyed from the cell surface to trigger the apoptotic death of a cell. The pathway starts with a ligand binding to a death domain receptor on the cell surface, and ends when the execution phase of apoptosis is triggered." ;
    evo:isDeprecated false ;
    evo:label "extrinsic apoptotic signaling pathway via death domain receptors" ;
    evo:parent go:GO_0097191 ;
    evo:termID "GO:0008625" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0008626/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals induced by granzymes which triggers the apoptotic death of a cell. The pathway starts with reception of a granzyme signal, and ends when the execution phase of apoptosis is triggered. Granzymes are serine proteases that are secreted by cytotoxic T cells and natural killer cells to induce apoptosis in target cells." ;
    evo:isDeprecated false ;
    evo:label "granzyme-mediated apoptotic signaling pathway" ;
    evo:parent go:GO_0097190,
        go:GO_0140507 ;
    evo:termID "GO:0008626" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0008627/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a cell. The pathway is induced in response to changes in intracellular ion homeostasis, and ends when the execution phase of apoptosis is triggered." ;
    evo:isDeprecated false ;
    evo:label "intrinsic apoptotic signaling pathway in response to osmotic stress" ;
    evo:parent go:GO_0071470,
        go:GO_0097193 ;
    evo:termID "GO:0008627" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0008628/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals mediated by the detection of a hormone, and which triggers the apoptotic signaling pathway in a cell. The pathway starts with reception of a hormone signal, and ends when the execution phase of apoptosis is triggered." ;
    evo:isDeprecated false ;
    evo:label "hormone-mediated apoptotic signaling pathway" ;
    evo:parent go:GO_0009755,
        go:GO_0097190 ;
    evo:termID "GO:0008628" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0008630/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a cell. The pathway is induced by the detection of DNA damage, and ends when the execution phase of apoptosis is triggered." ;
    evo:isDeprecated false ;
    evo:label "intrinsic apoptotic signaling pathway in response to DNA damage" ;
    evo:parent go:GO_0006974,
        go:GO_0097193 ;
    evo:termID "GO:0008630" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0008631/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a cell. The pathway is induced in response to oxidative stress, a state often resulting from exposure to high levels of reactive oxygen species, and ends when the execution phase of apoptosis is triggered." ;
    evo:isDeprecated false ;
    evo:label "intrinsic apoptotic signaling pathway in response to oxidative stress" ;
    evo:parent go:GO_0097193 ;
    evo:termID "GO:0008631" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0008637/2025-10-10> a evo:TermVersion ;
    evo:definition "The morphological and physiological alterations undergone by mitochondria during apoptosis." ;
    evo:isDeprecated false ;
    evo:label "apoptotic mitochondrial changes" ;
    evo:parent go:GO_0007005 ;
    evo:termID "GO:0008637" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0008656/2025-10-10> a evo:TermVersion ;
    evo:definition "Binds to and increases the rate of proteolysis catalyzed by a cysteine-type endopeptidase involved in the apoptotic process." ;
    evo:isDeprecated false ;
    evo:label "cysteine-type endopeptidase activator activity involved in apoptotic process" ;
    evo:parent go:GO_0016505,
        go:GO_0043028 ;
    evo:termID "GO:0008656" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0009561/2025-10-10> a evo:TermVersion ;
    evo:definition "The process whose specific outcome is the progression of the embryo sac over time, from its formation as the megaspore to the mature structure. The process begins when three of the four haploid megaspores disintegrate, and the fourth undergoes mitosis giving rise to a binucleate syncytial embryo sac. The two haploid nuclei migrate to the opposite poles of the embryo sac and then undergo two rounds of mitosis generating four haploid nuclei at each pole. One nucleus from each set of four migrates to the center of the cell. Cellularization occurs, resulting in an eight-nucleate seven-celled structure. This structure contains two synergid cells and an egg cell at the micropylar end, and three antipodal cells at the other end. A binucleate endosperm mother cell is formed at the center." ;
    evo:isDeprecated false ;
    evo:label "megagametogenesis" ;
    evo:termID "GO:0009561" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0009626/2025-10-10> a evo:TermVersion ;
    evo:definition "The rapid, localized death of plant cells in response to invasion by a pathogen." ;
    evo:isDeprecated false ;
    evo:label "plant-type hypersensitive response" ;
    evo:parent go:GO_0033554,
        go:GO_0034050,
        go:GO_0045087 ;
    evo:termID "GO:0009626" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0009653/2025-10-10> a evo:TermVersion ;
    evo:definition "The process in which anatomical structures are generated and organized. Morphogenesis pertains to the creation of form." ;
    evo:isDeprecated false ;
    evo:label "anatomical structure morphogenesis" ;
    evo:termID "GO:0009653" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0009755/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals mediated by the detection of a hormone." ;
    evo:isDeprecated false ;
    evo:label "hormone-mediated signaling pathway" ;
    evo:termID "GO:0009755" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0009856/2025-10-10> a evo:TermVersion ;
    evo:definition "The cascade of biological processes occurring in plants beginning when the pollen lands on the female reproductive organs of a plant and continuing up to, but not including, fertilization, as defined by sperm-egg cell fusion." ;
    evo:isDeprecated false ;
    evo:label "pollination" ;
    evo:termID "GO:0009856" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0009862/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals mediated by salicylic acid involved in systemic acquired resistance." ;
    evo:isDeprecated false ;
    evo:label "systemic acquired resistance, salicylic acid mediated signaling pathway" ;
    evo:termID "GO:0009862" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0009966/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that modulates the frequency, rate or extent of signal transduction." ;
    evo:isDeprecated false ;
