<http://purl.obolibrary.org/obo/GO_1990127/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a cell. The pathway is induced by the cell cycle regulator phosphoprotein p53, or an equivalent protein, in response to the detection of osmotic stress, and ends when the execution phase of apoptosis is triggered." ;
    evo:isDeprecated false ;
    evo:label "intrinsic apoptotic signaling pathway in response to osmotic stress by p53 class mediator" ;
    evo:parent go:GO_0008627,
        go:GO_0072332 ;
    evo:termID "GO:1990127" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_1990134/2025-10-10> a evo:TermVersion ;
    evo:definition "An apoptotic process in a palatal shelf epithelial cell that contributes to the shaping of the palatal shelf." ;
    evo:isDeprecated false ;
    evo:label "epithelial cell apoptotic process involved in palatal shelf morphogenesis" ;
    evo:parent go:GO_0060561,
        go:GO_1904019 ;
    evo:termID "GO:1990134" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_1990144/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a cell. The pathway is induced in response to hypoxia (lowered oxygen tension). Hypoxia, defined as a decline in O2 levels below normoxic levels of 20.8 - 20.95%, results in metabolic adaptation at both the cellular and organismal level. The pathway ends when the execution phase of apoptosis is triggered." ;
    evo:isDeprecated false ;
    evo:label "intrinsic apoptotic signaling pathway in response to hypoxia" ;
    evo:parent go:GO_0097193 ;
    evo:termID "GO:1990144" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_1990442/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a cell. The pathway is induced in response to nitrosative stress; a state often resulting from exposure to high levels of nitric oxide (NO) or the highly reactive oxidant peroxynitrite, which is produced following interaction of NO with superoxide anions." ;
    evo:isDeprecated false ;
    evo:label "intrinsic apoptotic signaling pathway in response to nitrosative stress" ;
    evo:parent go:GO_0071500,
        go:GO_0097193 ;
    evo:termID "GO:1990442" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_1990713/2025-10-10> a evo:TermVersion ;
    evo:definition "A protein complex that negatively regulates apoptotic processes. In human, this anti-apoptotic complex is a homodimer of BIRC5 (survivin) and provides one survivin molecule to the chromosomal passenger complex (CPC)." ;
    evo:isDeprecated false ;
    evo:label "survivin complex" ;
    evo:parent go:GO_0140513 ;
