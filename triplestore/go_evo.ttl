<http://purl.obolibrary.org/obo/GO_0052040/2026-01-23> a evo:TermVersion ;
    evo:definition "A process in which a symbiont gene product alters or subverts host programmed cell death, leading to a change in the frequency, rate or extent of host programmed cell death in the host cell. The host is defined as the larger of the organisms involved in a symbiotic interaction." ;
    evo:isDeprecated false ;
    evo:label "symbiont-mediated perturbation of host programmed cell death" ;
    evo:parent go:GO_0044068 ;
    evo:previousVersion <http://purl.obolibrary.org/obo/GO_0052040/2025-10-10> ;
    evo:termID "GO:0052040" ;
