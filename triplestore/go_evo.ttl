    evo:label "TRAIL receptor activity" ;
    evo:parent go:GO_0005035 ;
    evo:termID "GO:0036463" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0036480/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a neuron. The pathway is induced in response to oxidative stress, a state often resulting from exposure to high levels of reactive oxygen species, and ends when the execution phase of apoptosis is triggered." ;
    evo:isDeprecated false ;
    evo:label "neuron intrinsic apoptotic signaling pathway in response to oxidative stress" ;
    evo:parent go:GO_0008631 ;
    evo:termID "GO:0036480" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0036481/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a cell. The pathway is induced in response to hydrogen peroxide (H2O2)." ;
    evo:isDeprecated false ;
    evo:label "intrinsic apoptotic signaling pathway in response to hydrogen peroxide" ;
    evo:parent go:GO_0008631 ;
    evo:termID "GO:0036481" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0036482/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a neuron in response to hydrogen peroxide." ;
    evo:isDeprecated false ;
