<http://purl.obolibrary.org/obo/GO_0097048/2026-01-23> a evo:TermVersion ;
    evo:definition "Any apoptotic process in a dendritic cell, a cell of hematopoietic origin, typically resident in particular tissues, specialized in the uptake, processing, and transport of antigens to lymph nodes for the purpose of stimulating an immune response via T cell activation." ;
    evo:isDeprecated false ;
