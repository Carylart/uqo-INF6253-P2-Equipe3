    evo:termID "GO:0048018" ;
    evo:version <http://purl.obolibrary.org/obo/version/2026-01-23> .

<http://purl.obolibrary.org/obo/GO_0048102/2026-01-23> a evo:TermVersion ;
    evo:definition "A form of programmed cell death that is accompanied by the formation of autophagosomes. Autophagic cell death is characterized by lack of chromatin condensation and massive vacuolization of the cytoplasm, with little or no uptake by phagocytic cells." ;
    evo:isDeprecated false ;
    evo:label "autophagic cell death" ;
    evo:parent go:GO_0012501 ;
    evo:previousVersion <http://purl.obolibrary.org/obo/GO_0048102/2025-10-10> ;
