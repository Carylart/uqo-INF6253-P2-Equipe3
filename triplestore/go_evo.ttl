<http://purl.obolibrary.org/obo/GO_0046777/2025-10-10> a evo:TermVersion ;
    evo:definition "The phosphorylation by a protein of one or more of its own amino acid residues (cis-autophosphorylation), or residues on an identical protein (trans-autophosphorylation)." ;
    evo:isDeprecated false ;
    evo:label "protein autophosphorylation" ;
    evo:termID "GO:0046777" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0046902/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that modulates the frequency, rate or extent of the passage or uptake of molecules by the mitochondrial membrane." ;
    evo:isDeprecated false ;
    evo:label "regulation of mitochondrial membrane permeability" ;
    evo:termID "GO:0046902" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0048018/2025-10-10> a evo:TermVersion ;
    evo:definition "The activity of a gene product that interacts with a receptor to effect a change in the activity of the receptor. Ligands may be produced by the same cell that expresses the receptor. Ligands may also be expressed at the plasma membrane of an adjacent cell (e.g. Notch ligands) or be secreted and diffuse extracellularly from their point of origin to the receiving cell (e.g. interleukins)." ;
    evo:isDeprecated false ;
    evo:label "receptor ligand activity" ;
    evo:termID "GO:0048018" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0048102/2025-10-10> a evo:TermVersion ;
    evo:definition "A form of programmed cell death that is accompanied by the formation of autophagosomes. Autophagic cell death is characterized by lack of chromatin condensation and massive vacuolization of the cytoplasm, with little or no uptake by phagocytic cells." ;
    evo:isDeprecated false ;
    evo:label "autophagic cell death" ;
    evo:parent go:GO_0012501 ;
    evo:termID "GO:0048102" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0048468/2025-10-10> a evo:TermVersion ;
    evo:definition "The cellular developmental process in which a specific cell progresses from an immature to a mature state. Cell development start once cell commitment has taken place." ;
    evo:isDeprecated false ;
    evo:label "cell development" ;
    evo:termID "GO:0048468" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0048477/2025-10-10> a evo:TermVersion ;
    evo:definition "The complete process of formation and maturation of an ovum or female gamete from a primordial female germ cell. Examples of this process are found in Mus musculus and Drosophila melanogaster." ;
    evo:isDeprecated false ;
    evo:label "oogenesis" ;
    evo:termID "GO:0048477" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0048514/2025-10-10> a evo:TermVersion ;
    evo:definition "The process in which the anatomical structures of blood vessels are generated and organized. The blood vessel is the vasculature carrying blood." ;
    evo:isDeprecated false ;
    evo:label "blood vessel morphogenesis" ;
    evo:termID "GO:0048514" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0048522/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that activates or increases the frequency, rate or extent of a cellular process, any of those that are carried out at the cellular level, but are not necessarily restricted to a single cell. For example, cell communication occurs among more than one cell, but occurs at the cellular level." ;
    evo:isDeprecated false ;
    evo:label "positive regulation of cellular process" ;
    evo:termID "GO:0048522" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0048523/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that stops, prevents, or reduces the frequency, rate or extent of a cellular process, any of those that are carried out at the cellular level, but are not necessarily restricted to a single cell. For example, cell communication occurs among more than one cell, but occurs at the cellular level." ;
    evo:isDeprecated false ;
    evo:label "negative regulation of cellular process" ;
    evo:termID "GO:0048523" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0048592/2025-10-10> a evo:TermVersion ;
    evo:definition "The process in which the anatomical structures of the eye are generated and organized." ;
    evo:isDeprecated false ;
    evo:label "eye morphogenesis" ;
    evo:termID "GO:0048592" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0048856/2025-10-10> a evo:TermVersion ;
    evo:definition "The biological process whose specific outcome is the progression of an anatomical structure from an initial condition to its mature state. This process begins with the formation of the structure and ends with the mature structure, whatever form that may be including its natural destruction. An anatomical structure is any biological entity that occupies space and is distinguished from its surroundings. Anatomical structures can be macroscopic such as a carpel, or microscopic such as an acrosome." ;
    evo:isDeprecated false ;
    evo:label "anatomical structure development" ;
    evo:termID "GO:0048856" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0048869/2025-10-10> a evo:TermVersion ;
    evo:definition "A biological process whose specific outcome is the progression of a cell over time from an initial condition to a later condition." ;
    evo:isDeprecated false ;
    evo:label "cellular developmental process" ;
    evo:termID "GO:0048869" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0048873/2025-10-10> a evo:TermVersion ;
    evo:definition "Any biological process involved in the maintenance of the steady-state number of cells within a population of cells in a tissue." ;
    evo:isDeprecated false ;
    evo:label "homeostasis of number of cells within a tissue" ;
    evo:termID "GO:0048873" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0050729/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that activates or increases the frequency, rate or extent of the inflammatory response." ;
    evo:isDeprecated false ;
    evo:label "positive regulation of inflammatory response" ;
    evo:termID "GO:0050729" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0050793/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that modulates the frequency, rate or extent of development, the biological process whose specific outcome is the progression of a multicellular organism over time from an initial condition (e.g. a zygote, or a young adult) to a later condition (e.g. a multicellular animal or an aged adult)." ;
    evo:isDeprecated false ;
    evo:label "regulation of developmental process" ;
    evo:termID "GO:0050793" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0050794/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that modulates the frequency, rate or extent of a cellular process, any of those that are carried out at the cellular level, but are not necessarily restricted to a single cell. For example, cell communication occurs among more than one cell, but occurs at the cellular level." ;
    evo:isDeprecated false ;
    evo:label "regulation of cellular process" ;
    evo:termID "GO:0050794" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0050853/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals initiated by the cross-linking of an antigen receptor on a B cell." ;
    evo:isDeprecated false ;
    evo:label "B cell receptor signaling pathway" ;
    evo:termID "GO:0050853" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0051049/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that modulates the frequency, rate or extent of the directed movement of substances (such as macromolecules, small molecules, ions) into, out of or within a cell, or between cells, by means of some agent such as a transporter or pore." ;
    evo:isDeprecated false ;
    evo:label "regulation of transport" ;
    evo:termID "GO:0051049" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0051050/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that activates or increases the frequency, rate or extent of the directed movement of substances (such as macromolecules, small molecules, ions) into, out of or within a cell, or between cells, by means of some agent such as a transporter or pore." ;
    evo:isDeprecated false ;
    evo:label "positive regulation of transport" ;
    evo:termID "GO:0051050" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0051093/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that stops, prevents or reduces the rate or extent of development, the biological process whose specific outcome is the progression of an organism over time from an initial condition (e.g. a zygote, or a young adult) to a later condition (e.g. a multicellular animal or an aged adult)." ;
    evo:isDeprecated false ;
    evo:label "negative regulation of developmental process" ;
    evo:termID "GO:0051093" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0051094/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that activates or increases the rate or extent of development, the biological process whose specific outcome is the progression of an organism over time from an initial condition (e.g. a zygote, or a young adult) to a later condition (e.g. a multicellular animal or an aged adult)." ;
    evo:isDeprecated false ;
    evo:label "positive regulation of developmental process" ;
    evo:termID "GO:0051094" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0051402/2025-10-10> a evo:TermVersion ;
    evo:definition "Any apoptotic process in a neuron, the basic cellular unit of nervous tissue. Each neuron consists of a body, an axon, and dendrites. Their purpose is to receive, conduct, and transmit impulses in the nervous system." ;
    evo:isDeprecated false ;
    evo:label "neuron apoptotic process" ;
    evo:parent go:GO_0006915 ;
    evo:termID "GO:0051402" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0051709/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that modulates the frequency, rate or extent of the killing by an organism of cells in another organism." ;
    evo:isDeprecated false ;
    evo:label "regulation of killing of cells of another organism" ;
    evo:termID "GO:0051709" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0051712/2025-10-10> a evo:TermVersion ;
    evo:definition "Any process that activates or increases the frequency, rate or extent of the killing by an organism of cells in another organism." ;
    evo:isDeprecated false ;
    evo:label "positive regulation of killing of cells of another organism" ;
    evo:parent go:GO_0031343,
        go:GO_0043068,
        go:GO_0051709 ;
