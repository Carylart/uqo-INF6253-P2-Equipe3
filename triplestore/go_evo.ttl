        go:GO_0036481 ;
    evo:termID "GO:0036482" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0036483/2025-10-10> a evo:TermVersion ;
    evo:definition "The series of molecular signals in which an intracellular signal is conveyed to trigger the apoptotic death of a neuron. The pathway is induced in response to a stimulus indicating endoplasmic reticulum (ER) stress, and ends when the execution phase of apoptosis is triggered. ER stress usually results from the accumulation of unfolded or misfolded proteins in the ER lumen." ;
    evo:isDeprecated false ;
    evo:label "neuron intrinsic apoptotic signaling pathway in response to endoplasmic reticulum stress" ;
    evo:parent go:GO_0070059 ;
    evo:termID "GO:0036483" ;
