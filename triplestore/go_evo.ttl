    evo:parent go:GO_0097468 ;
    evo:termID "GO:0010343" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

<http://purl.obolibrary.org/obo/GO_0010363/2025-10-10> a evo:TermVersion ;
    evo:definition "Any endogenous process that modulates the frequency, rate or extent of the plant hypersensitive response." ;
