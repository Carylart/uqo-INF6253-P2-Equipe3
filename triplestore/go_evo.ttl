    evo:definition "Any process that increases the rate, frequency or extent of a necroptotic process, a necrotic cell death process that results from the activation of endogenous cellular processes, such as signaling involving death domain receptors or Toll-like receptors." ;
    evo:isDeprecated false ;
    evo:label "positive regulation of necroptotic process" ;
    evo:parent go:GO_0060544,
        go:GO_0062100 ;
    evo:termID "GO:0060545" ;
    evo:version <http://purl.obolibrary.org/obo/version/2025-10-10> .

